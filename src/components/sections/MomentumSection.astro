---
import { Image } from 'astro:assets';
import { ArrowIcon, ButtonPill } from "@components/ButtonPill";
import momentumHero from '@images/momentum-hero.png';
import sectionPortfolioBg from '@images/section-portfolio-bg.jpg';
import webbyNominee from '@images/webby-nominee.png';
import supVideo from '@videos/sup_02_720.mp4';
---

<section class="relative cc overflow-hidden pb-114 pt-95 text-white" aria-labelledby="momentum-title">
  <div class="pointer-events-none absolute inset-0" aria-hidden>
    <Image
      src={sectionPortfolioBg}
      alt=""
      width={sectionPortfolioBg.width}
      height={sectionPortfolioBg.height}
      class="absolute inset-0 size-full object-cover"
    />
    <div class="absolute inset-0 bg-sws-bleed-overlay" />
  </div>
  <div class="relative z-1 mx-auto">
    <div class="flex flex-col lg:flex-row items-start justify-center rs-gap-2">
      <div class="basis-1/3 flex flex-col justify-start gap-8 pr-[clamp(0rem,2vw,38px)]">
        <p class="m-0 mb-8 text-21 leading-snug text-white">Lasting Partnerships</p>
        <div>
          <h2
            id="momentum-title"
            class="m-0 mb-2.5 font-serif text-[clamp(2rem,3vw,45px)] font-normal leading-tight"
          >
            Momentum
          </h2>
          <p class="m-0 text-21 leading-snug">
            Mauris vel nunc rutrum, semper neque a, venenatis metus. Nulla egestas, enim ut blandit pulvinar, lorem tellus
            pulvinar ex, a eleifend ante arcu et nulla. Fusce et cursus libero. Nullam vitae lacus quis augue semper luctus
            nec non ex.&nbsp;
          </p>
          <ButtonPill as="a" href="https://momentum.stanford.edu/">
            Visit Momentum
            <ArrowIcon />
          </ButtonPill>
        </div>
      </div>
      <div class="basis-2/3 relative overflow-hidden rounded-md">
        <video autoplay loop muted playsinline class="size-full object-cover">
          <source src={supVideo} type="video/mp4" />
          Your browser does not support the video tag.
        </video>
        <div class="absolute bottom-[clamp(12px,3vw,24px)] right-[clamp(12px,3vw,24px)] z-2 flex max-w-[calc(100%-24px)] flex-col gap-1 rounded-lg bg-digital-blue p-1.5">
        </div>
      </div>
    </div>
    <div class="pt-95 text-center">
      <a class="text-19 leading-snug text-white/95" href="#">
        <span class="underline decoration-sws-red-bright underline-offset-4 hocus-visible:decoration-digital-red hover:decoration-2">
          Learn more about our work
        </span>
      </a>
    </div>
  </div>
</section>
<section class="relative overflow-hidden px-[clamp(1.25rem,5vw,100px)] pb-114 pt-95 text-white" aria-labelledby="momentum-title">
  <div class="pointer-events-none absolute inset-0" aria-hidden>
    <Image
      src={sectionPortfolioBg}
      alt=""
      width={sectionPortfolioBg.width}
      height={sectionPortfolioBg.height}
      class="absolute inset-0 size-full object-cover"
    />
    <div class="absolute inset-0 bg-sws-bleed-overlay" />
  </div>
  <div class="relative z-1 mx-auto">
    <div class="flex flex-wrap items-start justify-center gap-8">
      <div class="flex max-w-532 flex-[1_1_280px] flex-col justify-start gap-8 pr-[clamp(0rem,2vw,38px)]">
        <p class="m-0 mb-8 text-21 leading-snug text-white">Lasting Partnerships</p>
        <div>
          <h2
            id="momentum-title"
            class="m-0 mb-2.5 font-serif text-[clamp(2rem,3vw,45px)] font-normal leading-tight"
          >
            Momentum
          </h2>
          <p class="m-0 text-21 leading-snug">
            Mauris vel nunc rutrum, semper neque a, venenatis metus. Nulla egestas, enim ut blandit pulvinar, lorem tellus
            pulvinar ex, a eleifend ante arcu et nulla. Fusce et cursus libero. Nullam vitae lacus quis augue semper luctus
            nec non ex.&nbsp;
          </p>
          <ButtonPill as="a" href="https://momentum.stanford.edu/">
            Visit Momentum
            <ArrowIcon />
          </ButtonPill>
        </div>
      </div>
      <div class="relative max-w-768 min-h-400 flex-[1_1_320px] overflow-hidden rounded-md border border-[#2e2d29] bg-sws-momentum-frame">
        <Image src={momentumHero} alt="Momentum campaign creative" width={momentumHero.width} height={momentumHero.height} class="size-full object-cover" />
        <div class="absolute bottom-[clamp(12px,3vw,24px)] right-[clamp(12px,3vw,24px)] z-2 flex max-w-[calc(100%-24px)] flex-col gap-1 rounded-lg bg-digital-blue p-1.5">
          <Image src={webbyNominee} alt="Webby Awards" width={webbyNominee.width} height={webbyNominee.height} class="h-auto w-90" />
        </div>
      </div>
    </div>
    <div class="pt-95 text-center">
      <a class="text-19 leading-snug text-white/95" href="#">
        <span class="underline decoration-sws-red-bright underline-offset-4 hocus-visible:decoration-digital-red hover:decoration-2">
          Learn more about our work
        </span>
      </a>
    </div>
  </div>
</section>
