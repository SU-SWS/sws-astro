---
import '../index.css';
import { Font } from 'astro:assets';
import { GlobalFooter } from '@components/GlobalFooter/GlobalFooter';
import { FooterLocal } from '@components/FooterLocal';

interface Props {
  title?: string;
  footerHeading?: string;
  footerButtonHref?: string;
  footerButtonLabel?: string;
  footerActiveLabel?: string;
}

const {
  title = "Stanford Web Services",
  footerHeading = "We’d love to hear about what you’re working on.",
  footerButtonHref = "#",
  footerButtonLabel = "Connect with us",
  footerActiveLabel,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <Font cssVariable="--font-serif" />
    <Font cssVariable="--font-sans" />
    <Font cssVariable="--font-stanford" />
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-P8XKF6XL');</script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-P8XKF6XL"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <slot />
    <FooterLocal
      heading={footerHeading}
      buttonHref={footerButtonHref}
      buttonLabel={footerButtonLabel}
      activeLabel={footerActiveLabel}
    />
    <GlobalFooter />
  </body>
</html>
